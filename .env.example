# ─────────────────────────────────────────────────────────────
# .env.example — final_amd unified orchestrator
# Copy to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── AMD Developer Cloud (for creating/managing GPU Droplets) ──
AMD_TOKEN=your_amd_api_key_here
AMD_SSH_KEY_NAME=your_ssh_key_name
AMD_SSH_PUBLIC_KEY=your_public_key_content_here
AMD_SSH_PRIVATE_KEY_PATH=/path/to/your/private/key
AMD_REGION=atl1
AMD_DEFAULT_VM_SIZE=gpu-mi300x1-192gb-devcloud
AMD_GPU_IMAGE=amddevelopercloud-pytorch2100rocm724
AMD_DOCKER_BASE_IMAGE=rocm/pytorch:rocm7.2.4_ubuntu24.04_py3.12_pytorch_2.10.0

# ── LLM — Fireworks AI (for generating scripts, code review, cloud workflow queries) ──
FIREWORKS_API_KEY=your_fireworks_api_key
# accounts/fireworks/models/gemma-4-26b-a4b-it use gemma 4 using firecrawl ai
# eg- model = "accounts/fireworks/models/gemma-4-26b-a4b-it"
MODEL1= # primary — payload generation & review 
MODEL2= # secondary — for A/B or fallback

# ── Web Scraping — Firecrawl (for deep research agent) ──
FIRECRAWL_KEY=your_firecrawl_api_key

# ── Deep Research — Model (for web search / report writing) ──
CUSTOM_MODEL= # research agent's LLM
# CONTEXT_SIZE=128000
